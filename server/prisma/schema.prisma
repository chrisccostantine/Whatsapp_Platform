generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  OWNER
  ADMIN
  SALES_AGENT
  VIEWER
}

enum MembershipStatus {
  ACTIVE
  DISABLED
}

enum BusinessCategory {
  CLOTHING
  FURNITURE
  BEAUTY
  ELECTRONICS
  SERVICES
  OTHER
}

enum Currency {
  USD
  LBP
}

enum CustomerSource {
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  WEBSITE
  PHONE
  WALK_IN
  REFERRAL
  OTHER
}

enum LifecycleStage {
  NEW_LEAD
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
  EXISTING_CUSTOMER
}

enum FollowUpPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum FollowUpStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  OVERDUE
}

enum ActivityType {
  CUSTOMER_CREATED
  NOTE_ADDED
  TAG_ADDED
  TAG_REMOVED
  LEAD_STAGE_CHANGED
  FOLLOW_UP_CREATED
  FOLLOW_UP_COMPLETED
  CONVERSATION_ASSIGNED
  MESSAGE_SENT
  MESSAGE_RECEIVED
  QUOTATION_CREATED
  INVOICE_CREATED
  ORDER_CREATED
  ORDER_STATUS_CHANGED
  PAYMENT_RECORDED
}

enum SubscriptionPlan {
  STARTER
  GROWTH
  PRO
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum ConversationStatus {
  OPEN
  PENDING
  RESOLVED
  ARCHIVED
}

enum ConversationChannel {
  WHATSAPP
  MOCK_WHATSAPP
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  DOCUMENT
  AUDIO
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
  RECEIVED
}

enum WhatsAppConnectionStatus {
  DISCONNECTED
  CONNECTING
  CONNECTED
  ERROR
}

enum WhatsAppTemplateCategory {
  MARKETING
  UTILITY
  AUTHENTICATION
}

enum WhatsAppTemplateStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  PAUSED
  DISABLED
}

enum WebhookEventStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}

enum MarketingConsentStatus {
  OPTED_IN
  OPTED_OUT
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  PROCESSING
  PAUSED
  COMPLETED
  CANCELLED
  FAILED
}

enum CampaignRecipientStatus {
  PENDING
  QUEUED
  SENT
  DELIVERED
  READ
  REPLIED
  FAILED
  SKIPPED
}

enum CatalogItemType {
  PRODUCT
  SERVICE
}

enum QuotationStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}

enum InvoicePaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum OrderStatus {
  NEW
  CONFIRMED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURNED
}

enum PaymentMethod {
  CASH_ON_DELIVERY
  CASH
  CARD
  BANK_TRANSFER
  WHISH
  OMT
  OTHER
}

model User {
  id                 String          @id @default(uuid()) @db.Uuid
  email              String          @unique
  passwordHash       String
  firstName          String
  lastName           String
  emailVerifiedAt    DateTime?
  isActive           Boolean         @default(true)
  memberships        BusinessMember[]
  refreshTokens      RefreshToken[]
  resetTokens        PasswordResetToken[]
  createdNotes       CustomerNote[]  @relation("NoteAuthor")
  assignedCustomers  Customer[]      @relation("CustomerAssignee")
  assignedFollowUps  FollowUp[]      @relation("FollowUpAssignee")
  createdFollowUps   FollowUp[]      @relation("FollowUpCreator")
  assignedLeads      Lead[]          @relation("LeadAssignee")
  activities         Activity[]
  auditLogs          AuditLog[]
  assignedConversations Conversation[] @relation("ConversationAssignee")
  conversationAssignments ConversationAssignment[] @relation("AssignedMember")
  madeAssignments    ConversationAssignment[] @relation("AssignmentActor")
  sentMessages       Message[]         @relation("MessageSender")
  internalNotes      InternalNote[]
  createdCampaigns   Campaign[]        @relation("CampaignCreator")
  recordedConsents   ConsentRecord[]   @relation("ConsentRecorder")
  createdQuotations  Quotation[]       @relation("QuotationCreator")
  createdInvoices    Invoice[]         @relation("InvoiceCreator")
  assignedOrders     Order[]           @relation("OrderAssignee")
  createdOrders      Order[]           @relation("OrderCreator")
  recordedPayments   Payment[]         @relation("PaymentRecorder")
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  deletedAt          DateTime?
}

model Business {
  id                 String           @id @default(uuid()) @db.Uuid
  name               String
  slug               String           @unique
  category           BusinessCategory?
  country            String           @default("LB")
  currency           Currency         @default(USD)
  timezone           String           @default("Asia/Beirut")
  phone              String?
  logoUrl            String?
  address            String?
  email              String?
  website            String?
  taxNumber          String?
  employeeRange      String?
  mainObjective      String?
  onboardingComplete Boolean          @default(false)
  members            BusinessMember[]
  invitations        Invitation[]
  customers          Customer[]
  tags               Tag[]
  notes              CustomerNote[]
  activities         Activity[]
  followUps          FollowUp[]
  pipelines          Pipeline[]
  pipelineStages     PipelineStage[]
  leads              Lead[]
  subscription       Subscription?
  usageRecords       UsageRecord[]
  auditLogs          AuditLog[]
  conversations      Conversation[]
  conversationAssignments ConversationAssignment[]
  messages           Message[]
  messageAttachments MessageAttachment[]
  internalNotes      InternalNote[]
  whatsAppAccount    WhatsAppAccount?
  whatsAppTemplates  WhatsAppTemplate[]
  webhookEvents      WhatsAppWebhookEvent[]
  campaigns          Campaign[]
  campaignRecipients CampaignRecipient[]
  consentRecords     ConsentRecord[]
  products           Product[]
  quotations         Quotation[]
  quotationItems     QuotationItem[]
  invoices           Invoice[]
  invoiceItems       InvoiceItem[]
  payments           Payment[]
  orders             Order[]
  orderItems         OrderItem[]
  documentSequences  DocumentSequence[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  deletedAt          DateTime?
}

model BusinessMember {
  id         String           @id @default(uuid()) @db.Uuid
  businessId String           @db.Uuid
  userId     String           @db.Uuid
  role       MembershipRole
  status     MembershipStatus @default(ACTIVE)
  business   Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([businessId, userId])
  @@index([userId, status])
  @@index([businessId, role])
}

model RefreshToken {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  familyId    String    @db.Uuid
  tokenHash   String    @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  replacedBy  String?   @db.Uuid
  userAgent   String?
  ipAddress   String?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@index([userId, familyId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
}

model Invitation {
  id         String         @id @default(uuid()) @db.Uuid
  businessId String         @db.Uuid
  email      String
  role       MembershipRole
  tokenHash  String         @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  business   Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now())

  @@unique([businessId, email])
  @@index([businessId, expiresAt])
}

model Customer {
  id                 String          @id @default(uuid()) @db.Uuid
  businessId         String          @db.Uuid
  firstName          String
  lastName           String?
  phone              String?
  normalizedPhone    String?
  email              String?
  normalizedEmail    String?
  company            String?
  address            String?
  city               String?
  country            String          @default("LB")
  source             CustomerSource  @default(OTHER)
  lifecycleStage     LifecycleStage  @default(NEW_LEAD)
  assignedUserId     String?         @db.Uuid
  marketingOptIn     Boolean         @default(false)
  marketingOptInSource String?
  marketingOptInAt   DateTime?
  optedOutAt         DateTime?
  consentNotes       String?
  totalOrders        Int             @default(0)
  totalSpent         Decimal         @default(0) @db.Decimal(14, 2)
  lastContactAt      DateTime?
  business           Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  assignedUser       User?           @relation("CustomerAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  tags               CustomerTag[]
  notes              CustomerNote[]
  activities         Activity[]
  followUps          FollowUp[]
  leads              Lead[]
  conversations      Conversation[]
  consentRecords     ConsentRecord[]
  campaignRecipients CampaignRecipient[]
  quotations         Quotation[]
  invoices           Invoice[]
  orders             Order[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  deletedAt          DateTime?

  @@unique([businessId, normalizedPhone])
  @@unique([businessId, normalizedEmail])
  @@index([businessId, lifecycleStage])
  @@index([businessId, assignedUserId])
  @@index([businessId, createdAt])
}

model Tag {
  id          String        @id @default(uuid()) @db.Uuid
  businessId  String        @db.Uuid
  name        String
  color       String
  description String?
  business    Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customers   CustomerTag[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([businessId, name])
  @@index([businessId])
}

model CustomerTag {
  businessId String   @db.Uuid
  customerId String   @db.Uuid
  tagId      String   @db.Uuid
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([customerId, tagId])
  @@index([businessId, tagId])
}

model CustomerNote {
  id         String   @id @default(uuid()) @db.Uuid
  businessId String   @db.Uuid
  customerId String   @db.Uuid
  authorId   String   @db.Uuid
  content    String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  author     User     @relation("NoteAuthor", fields: [authorId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  @@index([businessId, customerId, createdAt])
}

model Activity {
  id         String       @id @default(uuid()) @db.Uuid
  businessId String       @db.Uuid
  customerId String?      @db.Uuid
  actorId    String?      @db.Uuid
  type       ActivityType
  metadata   Json?
  business   Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer   Customer?    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  actor      User?        @relation(fields: [actorId], references: [id], onDelete: SetNull)
  createdAt  DateTime     @default(now())

  @@index([businessId, createdAt])
  @@index([businessId, customerId, createdAt])
}

model FollowUp {
  id             String           @id @default(uuid()) @db.Uuid
  businessId     String           @db.Uuid
  customerId     String           @db.Uuid
  assignedUserId String           @db.Uuid
  createdById    String           @db.Uuid
  title          String
  description    String?
  dueAt          DateTime
  priority       FollowUpPriority @default(MEDIUM)
  status         FollowUpStatus   @default(PENDING)
  reminderAt     DateTime?
  completedAt    DateTime?
  business       Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer       Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  assignedUser   User             @relation("FollowUpAssignee", fields: [assignedUserId], references: [id])
  createdBy      User             @relation("FollowUpCreator", fields: [createdById], references: [id])
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?

  @@index([businessId, dueAt, status])
  @@index([businessId, assignedUserId])
}

model Pipeline {
  id         String          @id @default(uuid()) @db.Uuid
  businessId String          @db.Uuid
  name       String
  isDefault  Boolean         @default(false)
  business   Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  stages     PipelineStage[]
  leads      Lead[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([businessId, name])
  @@index([businessId])
}

model PipelineStage {
  id          String    @id @default(uuid()) @db.Uuid
  businessId  String    @db.Uuid
  pipelineId  String    @db.Uuid
  name        String
  position    Int
  probability Int       @default(0)
  color       String
  isWon       Boolean   @default(false)
  isLost      Boolean   @default(false)
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  pipeline    Pipeline  @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  leads       Lead[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([pipelineId, position])
  @@unique([pipelineId, name])
  @@index([businessId])
}

model Lead {
  id                String         @id @default(uuid()) @db.Uuid
  businessId        String         @db.Uuid
  pipelineId        String         @db.Uuid
  stageId           String         @db.Uuid
  customerId        String         @db.Uuid
  assignedUserId    String?        @db.Uuid
  title             String
  estimatedValue    Decimal        @default(0) @db.Decimal(14, 2)
  currency          Currency       @default(USD)
  probability       Int
  expectedCloseDate DateTime?
  source            CustomerSource @default(OTHER)
  notes             String?
  lostReason        String?
  business          Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  pipeline          Pipeline       @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  stage             PipelineStage  @relation(fields: [stageId], references: [id])
  customer          Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  assignedUser      User?          @relation("LeadAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  deletedAt         DateTime?

  @@index([businessId, stageId])
  @@index([businessId, assignedUserId])
  @@index([businessId, customerId])
}

model Subscription {
  id         String             @id @default(uuid()) @db.Uuid
  businessId String             @unique @db.Uuid
  plan       SubscriptionPlan   @default(STARTER)
  status     SubscriptionStatus @default(TRIALING)
  trialStart DateTime           @default(now())
  trialEnd   DateTime
  billingCycle String?
  business   Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
}

model UsageRecord {
  id         String   @id @default(uuid()) @db.Uuid
  businessId String   @db.Uuid
  metric     String
  quantity   Int
  periodStart DateTime
  periodEnd  DateTime
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([businessId, metric, periodStart])
  @@index([businessId, periodEnd])
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  businessId String   @db.Uuid
  actorId    String?  @db.Uuid
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  ipAddress  String?
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([businessId, createdAt])
  @@index([businessId, entityType, entityId])
}

model Conversation {
  id                    String              @id @default(uuid()) @db.Uuid
  businessId            String              @db.Uuid
  customerId            String              @db.Uuid
  assignedUserId        String?             @db.Uuid
  channel               ConversationChannel @default(MOCK_WHATSAPP)
  status                ConversationStatus  @default(OPEN)
  unreadCount           Int                 @default(0)
  lastMessagePreview    String?
  lastMessageAt         DateTime?
  lastCustomerMessageAt DateTime?
  sessionExpiresAt      DateTime?
  business              Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer              Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  assignedUser          User?               @relation("ConversationAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  assignments           ConversationAssignment[]
  messages              Message[]
  internalNotes         InternalNote[]
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  archivedAt            DateTime?

  @@unique([businessId, customerId, channel])
  @@index([businessId, status, lastMessageAt])
  @@index([businessId, assignedUserId, status])
  @@index([businessId, customerId])
}

model ConversationAssignment {
  id             String       @id @default(uuid()) @db.Uuid
  businessId     String       @db.Uuid
  conversationId String       @db.Uuid
  assignedUserId String       @db.Uuid
  assignedById   String       @db.Uuid
  unassignedAt   DateTime?
  business       Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  assignedUser   User         @relation("AssignedMember", fields: [assignedUserId], references: [id])
  assignedBy     User         @relation("AssignmentActor", fields: [assignedById], references: [id])
  createdAt      DateTime     @default(now())

  @@index([businessId, conversationId, createdAt])
  @@index([businessId, assignedUserId, unassignedAt])
}

model Message {
  id                String            @id @default(uuid()) @db.Uuid
  businessId        String            @db.Uuid
  conversationId    String            @db.Uuid
  senderUserId      String?           @db.Uuid
  replyToId         String?           @db.Uuid
  whatsAppAccountId String?           @db.Uuid
  templateId        String?           @db.Uuid
  providerMessageId String?
  idempotencyKey    String?
  direction         MessageDirection
  type              MessageType       @default(TEXT)
  status            MessageStatus
  body              String?
  errorCode         String?
  errorMessage      String?
  templateName      String?
  templateCategory  WhatsAppTemplateCategory?
  sentAt            DateTime?
  deliveredAt       DateTime?
  readAt            DateTime?
  receivedAt        DateTime?
  business          Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  conversation      Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderUser        User?             @relation("MessageSender", fields: [senderUserId], references: [id], onDelete: SetNull)
  replyTo           Message?          @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  whatsAppAccount   WhatsAppAccount?  @relation(fields: [whatsAppAccountId], references: [id], onDelete: SetNull)
  template          WhatsAppTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  replies           Message[]         @relation("MessageReplies")
  attachments       MessageAttachment[]
  campaignRecipient CampaignRecipient?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([businessId, providerMessageId])
  @@unique([businessId, idempotencyKey])
  @@index([businessId, conversationId, createdAt])
  @@index([businessId, status])
  @@index([businessId, whatsAppAccountId])
}

model MessageAttachment {
  id         String   @id @default(uuid()) @db.Uuid
  businessId String   @db.Uuid
  messageId  String   @db.Uuid
  fileName   String
  mimeType   String
  size       Int
  url        String
  providerMediaId String?
  checksum   String?
  metadata   Json?
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  message    Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([businessId, messageId])
}

model WhatsAppAccount {
  id                       String                   @id @default(uuid()) @db.Uuid
  businessId               String                   @unique @db.Uuid
  whatsAppBusinessAccountId String
  phoneNumberId            String                   @unique
  displayPhoneNumber       String
  verifiedName             String?
  encryptedAccessToken     String
  encryptedVerifyToken     String
  metaAppId                String?
  connectionStatus         WhatsAppConnectionStatus @default(CONNECTING)
  lastSyncAt               DateTime?
  lastError                String?
  business                 Business                 @relation(fields: [businessId], references: [id], onDelete: Cascade)
  templates                WhatsAppTemplate[]
  webhookEvents            WhatsAppWebhookEvent[]
  messages                 Message[]
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  disconnectedAt           DateTime?

  @@index([businessId, connectionStatus])
  @@index([whatsAppBusinessAccountId])
}

model WhatsAppTemplate {
  id            String                    @id @default(uuid()) @db.Uuid
  businessId    String                    @db.Uuid
  accountId     String                    @db.Uuid
  metaTemplateId String?
  name          String
  language      String
  category      WhatsAppTemplateCategory
  status        WhatsAppTemplateStatus
  header        Json?
  body          String
  footer        String?
  buttons       Json?
  variables     Json?
  business      Business                  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  account       WhatsAppAccount           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  messages      Message[]
  campaigns     Campaign[]
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  @@unique([accountId, name, language])
  @@unique([businessId, metaTemplateId])
  @@index([businessId, status])
}

model WhatsAppWebhookEvent {
  id          String             @id @default(uuid()) @db.Uuid
  businessId  String             @db.Uuid
  accountId   String             @db.Uuid
  eventKey    String
  payload     Json
  status      WebhookEventStatus @default(PENDING)
  attempts    Int                @default(0)
  lastError   String?
  processedAt DateTime?
  business    Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  account     WhatsAppAccount    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([accountId, eventKey])
  @@index([businessId, status, createdAt])
}

model InternalNote {
  id             String       @id @default(uuid()) @db.Uuid
  businessId     String       @db.Uuid
  conversationId String       @db.Uuid
  authorId       String       @db.Uuid
  body           String
  business       Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author         User         @relation(fields: [authorId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@index([businessId, conversationId, createdAt])
}

model ConsentRecord {
  id           String                 @id @default(uuid()) @db.Uuid
  businessId   String                 @db.Uuid
  customerId   String                 @db.Uuid
  recordedById String?                @db.Uuid
  status       MarketingConsentStatus
  source       String
  notes        String?
  business     Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer     Customer               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  recordedBy   User?                  @relation("ConsentRecorder", fields: [recordedById], references: [id], onDelete: SetNull)
  createdAt    DateTime               @default(now())

  @@index([businessId, customerId, createdAt])
  @@index([businessId, status, createdAt])
}

model Campaign {
  id              String              @id @default(uuid()) @db.Uuid
  businessId      String              @db.Uuid
  templateId      String              @db.Uuid
  createdById     String              @db.Uuid
  name            String
  audience        Json
  scheduledAt     DateTime?
  status          CampaignStatus      @default(DRAFT)
  totalRecipients Int                 @default(0)
  queuedCount     Int                 @default(0)
  sentCount       Int                 @default(0)
  deliveredCount  Int                 @default(0)
  readCount       Int                 @default(0)
  failedCount     Int                 @default(0)
  replyCount      Int                 @default(0)
  skippedCount    Int                 @default(0)
  startedAt       DateTime?
  completedAt     DateTime?
  lastError       String?
  business        Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  template        WhatsAppTemplate    @relation(fields: [templateId], references: [id], onDelete: Restrict)
  createdBy       User                @relation("CampaignCreator", fields: [createdById], references: [id], onDelete: Restrict)
  recipients      CampaignRecipient[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([businessId, status, createdAt])
  @@index([businessId, scheduledAt])
}

model CampaignRecipient {
  id                String                  @id @default(uuid()) @db.Uuid
  businessId        String                  @db.Uuid
  campaignId        String                  @db.Uuid
  customerId        String                  @db.Uuid
  messageId         String?                 @unique @db.Uuid
  phone             String
  variables         Json?
  status            CampaignRecipientStatus @default(PENDING)
  queuedAt          DateTime?
  sentAt            DateTime?
  deliveredAt       DateTime?
  readAt            DateTime?
  repliedAt         DateTime?
  failedAt          DateTime?
  skippedAt         DateTime?
  errorCode         String?
  errorMessage      String?
  business          Business                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  campaign          Campaign                @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer          Customer                @relation(fields: [customerId], references: [id], onDelete: Cascade)
  message           Message?                @relation(fields: [messageId], references: [id], onDelete: SetNull)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@unique([campaignId, customerId])
  @@index([businessId, status, createdAt])
  @@index([businessId, customerId, createdAt])
  @@index([campaignId, status])
}

model DocumentSequence {
  businessId String   @db.Uuid
  key        String
  value      Int      @default(0)
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  updatedAt  DateTime @updatedAt

  @@id([businessId, key])
}

model Product {
  id          String          @id @default(uuid()) @db.Uuid
  businessId  String          @db.Uuid
  name        String
  sku         String?
  type        CatalogItemType
  description String?
  price       Decimal         @db.Decimal(14, 2)
  currency    Currency
  taxRate     Decimal         @default(0) @db.Decimal(5, 2)
  isActive    Boolean         @default(true)
  business    Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  quotationItems QuotationItem[]
  invoiceItems InvoiceItem[]
  orderItems   OrderItem[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?

  @@unique([businessId, sku])
  @@index([businessId, type, isActive])
  @@index([businessId, name])
}

model Quotation {
  id              String          @id @default(uuid()) @db.Uuid
  businessId      String          @db.Uuid
  customerId      String          @db.Uuid
  createdById     String          @db.Uuid
  quotationNumber String
  issueDate       DateTime
  expiryDate      DateTime
  currency        Currency
  subtotal        Decimal         @db.Decimal(14, 2)
  discount        Decimal         @default(0) @db.Decimal(14, 2)
  tax             Decimal         @default(0) @db.Decimal(14, 2)
  total           Decimal         @db.Decimal(14, 2)
  notes           String?
  terms           String?
  status          QuotationStatus @default(DRAFT)
  business        Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer        Customer        @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdBy       User            @relation("QuotationCreator", fields: [createdById], references: [id], onDelete: Restrict)
  items           QuotationItem[]
  convertedInvoice Invoice?       @relation("QuotationInvoice")
  convertedOrder   Order?         @relation("QuotationOrder")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?

  @@unique([businessId, quotationNumber])
  @@index([businessId, status, issueDate])
  @@index([businessId, customerId, createdAt])
}

model QuotationItem {
  id          String     @id @default(uuid()) @db.Uuid
  businessId  String     @db.Uuid
  quotationId String     @db.Uuid
  productId   String?    @db.Uuid
  name        String
  description String?
  quantity    Decimal    @db.Decimal(12, 3)
  unitPrice   Decimal    @db.Decimal(14, 2)
  discount    Decimal    @default(0) @db.Decimal(14, 2)
  taxRate     Decimal    @default(0) @db.Decimal(5, 2)
  lineTotal   Decimal    @db.Decimal(14, 2)
  business    Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  quotation   Quotation  @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product     Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())

  @@index([businessId, quotationId])
  @@index([businessId, productId])
}

model Invoice {
  id              String               @id @default(uuid()) @db.Uuid
  businessId      String               @db.Uuid
  customerId      String               @db.Uuid
  createdById     String               @db.Uuid
  sourceQuotationId String?            @unique @db.Uuid
  invoiceNumber   String
  issueDate       DateTime
  dueDate         DateTime
  currency        Currency
  subtotal        Decimal              @db.Decimal(14, 2)
  discount        Decimal              @default(0) @db.Decimal(14, 2)
  tax             Decimal              @default(0) @db.Decimal(14, 2)
  total           Decimal              @db.Decimal(14, 2)
  amountPaid      Decimal              @default(0) @db.Decimal(14, 2)
  amountDue       Decimal              @db.Decimal(14, 2)
  paymentStatus   InvoicePaymentStatus @default(UNPAID)
  notes           String?
  terms           String?
  business        Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer        Customer             @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdBy       User                 @relation("InvoiceCreator", fields: [createdById], references: [id], onDelete: Restrict)
  sourceQuotation Quotation?           @relation("QuotationInvoice", fields: [sourceQuotationId], references: [id], onDelete: SetNull)
  items           InvoiceItem[]
  payments        Payment[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  deletedAt       DateTime?

  @@unique([businessId, invoiceNumber])
  @@index([businessId, paymentStatus, dueDate])
  @@index([businessId, customerId, createdAt])
}

model InvoiceItem {
  id          String    @id @default(uuid()) @db.Uuid
  businessId  String    @db.Uuid
  invoiceId   String    @db.Uuid
  productId   String?   @db.Uuid
  name        String
  description String?
  quantity    Decimal   @db.Decimal(12, 3)
  unitPrice   Decimal   @db.Decimal(14, 2)
  discount    Decimal   @default(0) @db.Decimal(14, 2)
  taxRate     Decimal   @default(0) @db.Decimal(5, 2)
  lineTotal   Decimal   @db.Decimal(14, 2)
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoice     Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product     Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())

  @@index([businessId, invoiceId])
  @@index([businessId, productId])
}

model Order {
  id                String               @id @default(uuid()) @db.Uuid
  businessId        String               @db.Uuid
  customerId        String               @db.Uuid
  createdById       String               @db.Uuid
  assignedUserId    String?              @db.Uuid
  sourceQuotationId String?              @unique @db.Uuid
  orderNumber       String
  currency          Currency
  subtotal          Decimal              @db.Decimal(14, 2)
  discount          Decimal              @default(0) @db.Decimal(14, 2)
  tax               Decimal              @default(0) @db.Decimal(14, 2)
  deliveryFee       Decimal              @default(0) @db.Decimal(14, 2)
  total             Decimal              @db.Decimal(14, 2)
  amountPaid        Decimal              @default(0) @db.Decimal(14, 2)
  paymentMethod     PaymentMethod
  paymentStatus     InvoicePaymentStatus @default(UNPAID)
  status            OrderStatus          @default(NEW)
  deliveryAddress   String?
  customerNotes     String?
  internalNotes     String?
  business          Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer          Customer             @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdBy         User                 @relation("OrderCreator", fields: [createdById], references: [id], onDelete: Restrict)
  assignedUser      User?                @relation("OrderAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  sourceQuotation   Quotation?           @relation("QuotationOrder", fields: [sourceQuotationId], references: [id], onDelete: SetNull)
  items             OrderItem[]
  payments          Payment[]
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  deletedAt         DateTime?

  @@unique([businessId, orderNumber])
  @@index([businessId, status, createdAt])
  @@index([businessId, paymentStatus])
  @@index([businessId, customerId, createdAt])
  @@index([businessId, assignedUserId, status])
}

model OrderItem {
  id          String    @id @default(uuid()) @db.Uuid
  businessId  String    @db.Uuid
  orderId     String    @db.Uuid
  productId   String?   @db.Uuid
  name        String
  description String?
  quantity    Decimal   @db.Decimal(12, 3)
  unitPrice   Decimal   @db.Decimal(14, 2)
  discount    Decimal   @default(0) @db.Decimal(14, 2)
  taxRate     Decimal   @default(0) @db.Decimal(5, 2)
  lineTotal   Decimal   @db.Decimal(14, 2)
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())

  @@index([businessId, orderId])
  @@index([businessId, productId])
}

model Payment {
  id           String        @id @default(uuid()) @db.Uuid
  businessId   String        @db.Uuid
  invoiceId    String?       @db.Uuid
  orderId      String?       @db.Uuid
  recordedById String        @db.Uuid
  amount       Decimal       @db.Decimal(14, 2)
  currency     Currency
  method       PaymentMethod
  reference    String?
  notes        String?
  paidAt       DateTime
  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoice      Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  order        Order?        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  recordedBy   User          @relation("PaymentRecorder", fields: [recordedById], references: [id], onDelete: Restrict)
  createdAt    DateTime      @default(now())

  @@index([businessId, invoiceId, paidAt])
  @@index([businessId, orderId, paidAt])
}
